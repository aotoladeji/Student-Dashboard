{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd university-dashboard && npm install",
  "buildCommand": "cd university-dashboard && npm run build",
  "outputDirectory": "university-dashboard/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
